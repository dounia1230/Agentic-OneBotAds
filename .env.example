APP_NAME=Agentic OneBotAds
ENVIRONMENT=development
API_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=qwen3:8b
EMBED_MODEL=nomic-embed-text:latest
ENABLE_LIVE_LLM=true
LLM_TEMPERATURE=0.2
LLM_REQUEST_TIMEOUT_SECONDS=90

ENABLE_RAG=true
CHROMA_PATH=vector_store/chroma
CHROMA_COLLECTION=onebotads_kb
KNOWLEDGE_BASE_PATH=data/knowledge_base
CAMPAIGNS_CSV_PATH=data/campaigns.csv

ENABLE_IMAGE_GENERATION=false
IMAGE_PROVIDER=diffusers
IMAGE_MODEL=runwayml/stable-diffusion-v1-5
OUTPUT_IMAGE_DIR=outputs/images
OUTPUT_REPORT_DIR=outputs/reports
